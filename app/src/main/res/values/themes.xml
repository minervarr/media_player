<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Media_player" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dim</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/green_bright</item>
        <item name="colorSecondaryVariant">@color/green_dim</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
    </style>

    <style name="Theme.Media_player.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/bg_surface</item>
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorSecondary">@color/green_bright</item>
    </style>
</resources>
